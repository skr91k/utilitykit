rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      // User must be authenticated and can only access their own user document
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Counter tasks collection
      match /counterTasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Task progress subcollection
        match /progress/{date} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Default counter collection (for Quick Count task)
      match /defaultCounter/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
